# Application
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://resume_ai:resume_ai_secret@localhost:5432/resume_ai_db

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=resumes
MINIO_SECURE=false

# ── Ollama ───────────────────────────────────────────────────────────
# Default: containers reach Ollama running NATIVELY on the host
# (Metal GPU on Mac → 10-30× faster than CPU-only Docker).
#
# Host setup (Mac):
#   brew install ollama && ollama serve
#   ollama pull llama3.2:3b
#   ollama pull qwen2.5:7b
#
# If you run Ollama on a remote machine, override:
#   OLLAMA_BASE_URL=http://<host-or-ip>:11434
#
# If you re-enable the in-Docker ollama service (see docker-compose.yaml),
# set this to:  OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_CODER=qwen2.5-coder:7b
OLLAMA_MODEL_GENERAL=qwen2.5:7b
OLLAMA_MODEL_FAST=llama3.2:3b

# File Upload
MAX_UPLOAD_SIZE=10485760
